#!/bin/bash
# ============================================================
# Git pre-commit hook — 布局静态检查
# ============================================================
# 安装：
#   bash scripts/install-git-hooks.sh
#
# 手动触发：
#   .githooks/pre-commit
# ============================================================

set -e

echo "🔍 运行静态布局 Lint..."
node scripts/lint-layout.mjs

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ 发现 ERROR 级布局问题。请修复后再提交。"
  echo "   临时绕过：git commit --no-verify"
  echo "   查看详情：npm run lint:layout"
  exit 1
fi

echo "✅ 布局 Lint 通过"
